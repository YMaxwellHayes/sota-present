{
  "id": "editorial-forest",
  "derived_from": "templates/slides/gallery/editorial-forest/design.md + styles.json",
  "ground_default": "bg",
  "grounds": {
    "bg": {
      "fill": "#efe7d4",
      "heading": "#2e4a2a",
      "body": "#1a1a17",
      "muted": "#3a5a36",
      "accent": "#d27e96",
      "surface": "#e6dcc4",
      "border": "#2e4a2a"
    },
    "bg_alt": {
      "fill": "#2e4a2a",
      "heading": "#efe7d4",
      "body": "#efe7d4",
      "muted": "#cdbf9f",
      "accent": "#e89cb1",
      "surface": "#243a21",
      "border": "#e89cb1"
    }
  },
  "fonts": {
    "display": "Source Serif 4",
    "body": "Source Serif 4",
    "mono": "JetBrains Mono",
    "cjk": "Noto Serif SC",
    "cjk_mono": "Noto Sans Mono CJK SC",
    "single_weight_display": false
  },
  "type_scale": {
    "hero": {
      "pt": 104,
