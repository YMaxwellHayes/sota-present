{
  "id": "cobalt-grid",
  "derived_from": "templates/slides/gallery/cobalt-grid/design.md + styles.json",
  "ground_default": "bg",
  "grounds": {
    "bg":     { "fill": "#f5f4ef", "heading": "#1a3a8a", "body": "#1a1a1a", "muted": "#6B6B6B", "accent": "#1a3a8a", "surface": "#ebe8e0", "border": "#1a3a8a" },
    "bg_alt": { "fill": "#1a3a8a", "heading": "#f5f4ef", "body": "#f5f4ef", "muted": "#c7cee8", "accent": "#a9b6f0", "surface": "#22459c", "border": "#a9b6f0" }
  },
  "fonts": {
    "display": "Newsreader",
    "body": "Hanken Grotesk",
    "mono": "DM Mono",
    "cjk": "Noto Serif SC",
    "cjk_mono": "Noto Sans Mono CJK SC",
    "single_weight_display": false
  },
  "type_scale": {
    "hero":        { "pt": 100, "weight": 400, "face": "display", "tracking": -0.008, "leading": 0.92, "transform": "none" },
    "display":     { "pt": 65,  "weight": 400, "face": "display", "tracking": -0.005, "leading": 1.0,  "transform": "none" },
    "headline":    { "pt": 46,  "weight": 400, "face": "display", "tracking": 0,      "leading": 0.95, "transform": "none" },
    "eyebrow":     { "pt": 13,  "weight": 600, "face": "body",    "tracking": 0.18,   "leading": 1.0,  "transform": "upper" },
    "body":        { "pt": 16,  "weight": 400, "face": "body",    "tracking": 0,      "leading": 1.5,  "transform": "none" },
    "bullet":      { "pt": 16,  "weight": 400, "face": "body",    "tracking": 0,      "leading": 1.4,  "transform": "none" },
    "caption":     { "pt": 11,  "weight": 400, "face": "mono",    "tracking": 0.06,   "leading": 1.0,  "transform": "none" },
    "stat_number": { "pt": 120, "weight": 400, "face": "display", "tracking": -0.015, "leading": 0.92, "transform": "none" },
    "stat_unit":   { "pt": 25,  "weight": 400, "face": "display", "tracking": -0.005, "leading": 1.0,  "transform": "none" },
    "quote":       { "pt": 55,  "weight": 400, "face": "display", "tracking": -0.005, "leading": 1.05, "transform": "none" },
    "card_title":  { "pt": 20,  "weight": 400, "face": "display", "tracking": 0,      "leading": 1.05, "transform": "none" }
  },
  "spacing": {
    "margin_x": 0.95, "margin_top": 0.6, "margin_bottom": 0.52,
    "gap_card": 0.3, "gap_bullet": 0.22, "card_pad": 0.46,
    "radius_card": 0.0, "rule_pt": 1.5, "rule_card_pt": 1.0
  },
  "components": {
    "footline": true, "pageno": true, "heading_rule": true,
    "marker": "square", "card_border": true, "card_fill": "surface", "monogram": false
  },
  "depth": { "mode": "flat", "shadow": false, "offset_dx": 0, "offset_dy": 0, "offset_color": "border" },
  "decor": [ { "type": "edge_bar", "where": "cover", "color": "accent" } ],
  "rules": {
    "no_em_dash": true, "lock_accent": true, "off_black_white": true,
    "mono_upper": true, "body_max_weight": 400, "display_force_bold": false
  }
}
