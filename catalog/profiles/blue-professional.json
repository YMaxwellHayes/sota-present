{
  "id": "blue-professional",
  "derived_from": "styles.json (blue-professional) + STYLE_PRESETS.md preset",
  "ground_default": "bg",
  "grounds": {
    "bg":     { "fill": "#FAF9F6", "heading": "#2563EB", "body": "#1a1a1a", "muted": "#6B7280", "accent": "#2563EB", "surface": "#FFFFFF", "border": "#D7DBE3" },
    "bg_alt": { "fill": "#1E3A8A", "heading": "#FFFFFF", "body": "#EAF1FF", "muted": "#A9C2F0", "accent": "#93C5FD", "surface": "#1E40AF", "border": "#93C5FD" }
  },
  "fonts": {
    "display": "DM Sans",
    "body": "DM Sans",
    "mono": "JetBrains Mono",
    "cjk": "Noto Sans SC",
    "cjk_mono": "Noto Sans Mono CJK SC",
    "single_weight_display": false
  },
  "type_scale": {
    "hero":        { "pt": 92, "weight": 700, "face": "display", "tracking": -0.02,  "leading": 0.96, "transform": "none" },
    "display":     { "pt": 56, "weight": 700, "face": "display", "tracking": -0.02,  "leading": 1.0,  "transform": "none" },
    "headline":    { "pt": 36, "weight": 700, "face": "display", "tracking": -0.015, "leading": 1.04, "transform": "none" },
    "eyebrow":     { "pt": 13, "weight": 500, "face": "mono",    "tracking": 0.14,   "leading": 1.0,  "transform": "upper" },
    "body":        { "pt": 18, "weight": 400, "face": "body",    "tracking": 0,      "leading": 1.4,  "transform": "none" },
    "bullet":      { "pt": 18, "weight": 400, "face": "body",    "tracking": 0,      "leading": 1.28, "transform": "none" },
    "caption":     { "pt": 11.5,"weight": 500,"face": "mono",    "tracking": 0.14,   "leading": 1.0,  "transform": "upper" },
    "stat_number": { "pt": 84, "weight": 700, "face": "display", "tracking": -0.02,  "leading": 0.94, "transform": "none" },
    "stat_unit":   { "pt": 36, "weight": 700, "face": "display", "tracking": -0.01,  "leading": 0.94, "transform": "none" },
    "quote":       { "pt": 40, "weight": 700, "face": "display", "tracking": -0.01,  "leading": 1.12, "transform": "none" },
    "card_title":  { "pt": 24, "weight": 700, "face": "display", "tracking": -0.01,  "leading": 1.04, "transform": "none" }
  },
  "spacing": {
    "margin_x": 0.95, "margin_top": 0.6, "margin_bottom": 0.52,
    "gap_card": 0.3, "gap_bullet": 0.22, "card_pad": 0.46,
    "radius_card": 0.045, "rule_pt": 1.25, "rule_card_pt": 2.0
  },
  "components": {
    "footline": true, "pageno": true, "heading_rule": true,
    "marker": "square", "card_border": true, "card_fill": "surface", "monogram": false
  },
  "depth": { "mode": "flat", "shadow": false, "offset_dx": 0, "offset_dy": 0, "offset_color": "border" },
  "decor": [ { "type": "edge_bar", "where": "cover", "color": "accent" } ],
  "rules": {
    "no_em_dash": true, "lock_accent": true, "off_black_white": true,
    "mono_upper": true, "body_max_weight": 400, "display_force_bold": false
  },
  "section_ground": "bg_alt",
  "statement_ground": "bg_alt"
}
