{
  "id": "stencil-tablet",
  "derived_from": "templates/slides/gallery/stencil-tablet/design.md + styles.json",
  "ground_default": "bg",
  "grounds": {
    "bg":     { "fill": "#E2DCC9", "heading": "#0A0A0A", "body": "#0A0A0A", "muted": "#6B6B6B", "accent": "#EE7A2E", "surface": "#F4EFE0", "border": "#0A0A0A" },
    "bg_alt": { "fill": "#000000", "heading": "#E2DCC9", "body": "#E2DCC9", "muted": "#E2DCC9", "accent": "#EE7A2E", "surface": "#A06A3C", "border": "#E2DCC9" }
  },
  "fonts": {
    "display": "Stardos Stencil",
    "body": "Inter",
    "mono": "Barlow Condensed",
    "cjk": "Noto Sans SC",
    "cjk_mono": "Noto Sans Mono CJK SC",
    "single_weight_display": true
  },
  "type_scale": {
    "hero":        { "pt": 110, "weight": 400, "face": "display", "tracking": -0.015, "leading": 0.82, "transform": "upper" },
    "display":     { "pt": 60,  "weight": 400, "face": "display", "tracking": -0.005, "leading": 0.92, "transform": "upper" },
    "headline":    { "pt": 46,  "weight": 400, "face": "display", "tracking": -0.01,  "leading": 0.92, "transform": "upper" },
    "eyebrow":     { "pt": 12,  "weight": 800, "face": "mono",    "tracking": 0.14,   "leading": 1.0,  "transform": "upper" },
    "body":        { "pt": 16,  "weight": 400, "face": "body",    "tracking": 0,      "leading": 1.4,  "transform": "none" },
    "bullet":      { "pt": 16,  "weight": 400, "face": "body",    "tracking": 0,      "leading": 1.4,  "transform": "none" },
    "caption":     { "pt": 11,  "weight": 600, "face": "mono",    "tracking": 0.08,   "leading": 1.0,  "transform": "upper" },
    "stat_number": { "pt": 80,  "weight": 400, "face": "display", "tracking": -0.02,  "leading": 0.85, "transform": "none" },
    "stat_unit":   { "pt": 20,  "weight": 800, "face": "mono",    "tracking": 0.08,   "leading": 0.85, "transform": "upper" },
    "quote":       { "pt": 30,  "weight": 400, "face": "display", "tracking": -0.005, "leading": 1.05, "transform": "upper" },
    "card_title":  { "pt": 17,  "weight": 400, "face": "display", "tracking": -0.005, "leading": 1.15, "transform": "upper" }
  },
  "spacing": {
    "margin_x": 0.95, "margin_top": 0.6, "margin_bottom": 0.52,
    "gap_card": 0.3, "gap_bullet": 0.22, "card_pad": 0.46,
    "radius_card": 0.045, "rule_pt": 1.25, "rule_card_pt": 2.0
  },
  "components": {
    "footline": true, "pageno": true, "heading_rule": true,
    "marker": "square", "card_border": true, "card_fill": "surface", "monogram": false
  },
  "depth": { "mode": "flat", "shadow": false, "offset_dx": 0, "offset_dy": 0, "offset_color": "border" },
  "decor": [ { "type": "edge_bar", "where": "cover", "color": "accent" } ],
  "rules": {
    "no_em_dash": true, "lock_accent": true, "off_black_white": true,
    "mono_upper": true, "body_max_weight": 400, "display_force_bold": false
  }
}
